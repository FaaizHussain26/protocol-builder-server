# eSource Builder backend configuration.

# Port the API listens on.
PORT=8080

# MongoDB Atlas connection string. Optional for /api/build (stateless), but
# required for the /api/studies persistence endpoints. If unset, the server
# still boots and /api/build works; persistence endpoints return 503.
MONGODB_URI=

# Azure OpenAI (server-only — never exposed to the browser).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# Comma-separated list of allowed CORS origins (the frontend dev/prod URLs).
CORS_ORIGIN=http://localhost:5173

# ---- Vector "memory" (Phase 3) ----
# Embeddings are computed LOCALLY (Xenova/all-MiniLM-L6-v2, 384-dim) — no Azure
# embeddings deployment and no extra API key. The model downloads once on first
# use; set TRANSFORMERS_CACHE to persist it across deploys.
# TRANSFORMERS_CACHE=/var/cache/transformers
#
# Memory activates only when MONGODB_URI is set AND an Atlas Vector Search index
# named "study_vector" exists on the "studies" collection. The server tries to
# create it automatically on boot; if your tier blocks that, create it in the
# Atlas UI: field path "embedding", type "vector", 384 dimensions, similarity "cosine".
